# Environment
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="please-change-me-to-a-long-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Superuser (created on first boot if not exists)
SUPERUSER=admin
SUPERUSER_PASSWORD=admin

# TMDB (https://www.themoviedb.org/)
TMDB_API_KEY=

# qBittorrent
QB_URL=http://127.0.0.1:8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin
QB_CATEGORY_MOVIE=movies
QB_CATEGORY_TV=tv

# Jellyfin
JELLYFIN_URL=http://127.0.0.1:8096
JELLYFIN_API_KEY=

# Paths
DOWNLOAD_DIR=/downloads
LIBRARY_DIR_MOVIE=/media/movies
LIBRARY_DIR_TV=/media/tv
TRANSFER_TYPE=link

# Rename templates (Nunjucks)
MOVIE_RENAME_FORMAT={{title}} ({{year}})/{{title}} ({{year}}){{ ' - ' + resourcePix if resourcePix }}{{fileExt}}
TV_RENAME_FORMAT={{title}} ({{year}})/Season {{season}}/{{title}} - S{{season | pad2}}E{{episode | pad2}}{{fileExt}}

# Scheduler intervals (cron expressions)
CRON_SUBSCRIBE_SEARCH=0 */8 * * *
CRON_SUBSCRIBE_REFRESH=*/30 * * * *
CRON_TRANSFER_POLL=* * * * *
CRON_MEDIASERVER_SYNC=0 3 * * *
